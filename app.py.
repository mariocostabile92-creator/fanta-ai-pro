import pandas as pd
import ipywidgets as widgets
from IPython.display import display, clear_output, HTML

# 1. Caricamento dati (manteniamo quello di prima)
url_dati = "https://raw.githubusercontent.com/OpenFanta/fanta-data/main/data/players.csv"
try:
    df_reale = pd.read_csv(url_dati)
    df_reale = df_reale[['name', 'team', 'role', 'price']]
    messaggio = "✅ Sistema IA Online - Dati caricati"
except:
    df_reale = pd.DataFrame([{"name": "Lautaro", "team": "Inter", "role": "A", "price": 40}])
    messaggio = "⚠️ Database Offline"

# 2. Stile CSS (Aggiornato con il badge IA)
style = """
<style>
    .fanta-card {
        background: white; border-radius: 12px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        padding: 15px; margin: 10px 0; border-left: 8px solid #6f42c1; font-family: sans-serif;
    }
    .price { float: right; background: #2ecc71; color: white; padding: 5px 12px; border-radius: 20px; font-weight: bold; }
    .ia-box { background: #f8f1ff; border: 1px dashed #6f42c1; padding: 10px; border-radius: 8px; margin-top: 10px; }
    .ia-badge { background: #6f42c1; color: white; font-size: 0.7em; padding: 2px 6px; border-radius: 4px; font-weight: bold; }
</style>
"""
display(HTML(style))

output = widgets.Output()
ruolo_sel = widgets.Dropdown(options=['Tutti', 'A', 'C', 'D', 'P'], description='Ruolo:')
search_bar = widgets.Text(placeholder='Cerca calciatore...', description='Cerca:')
btn_aggiorna = widgets.Button(description="Analizza Mercato", button_style='primary')

def mostra_mercato(b):
    with output:
        clear_output()
        risultato = df_reale
        if ruolo_sel.value != 'Tutti':
            risultato = risultato[risultato['role'] == ruolo_sel.value]
        if search_bar.value:
            risultato = risultato[risultato['name'].str.contains(search_bar.value, case=False)]

        for _, row in risultato.head(10).iterrows():
            # --- LOGICA IA ADVISOR (La parte che monetizzi) ---
            if row['price'] > 30:
                consiglio = "💎 <b>Top Player:</b> Vale l'investimento, ma non superare i 45cr."
            elif row['price'] > 15:
                consiglio = "📈 <b>In Crescita:</b> Ottimo rapporto rendimento/prezzo."
            else:
                consiglio = "🎲 <b>Scommessa:</b> Costa poco, prendilo come ultimo slot."
            
            html_card = f"""
            <div class="fanta-card">
                <span class="price">{row['price']} cr</span>
                <div class="name" style="font-size:1.2em; font-weight:bold;">{row['name']}</div>
                <div class="meta" style="color:#666;">{row['team']} - {row['role']}</div>
                <div class="ia-box">
                    <span class="ia-badge">IA ADVISOR</span>
                    <p style="margin:5px 0 0 0; font-size:0.9em;">{consiglio}</p>
                </div>
            </div>
            """
            display(HTML(html_card))

btn_aggiorna.on_click(mostra_mercato)
print(messaggio)
display(ruolo_sel, search_bar, btn_aggiorna, output)
